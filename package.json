{
  "name": "douyin-insight",
  "version": "1.0.0",
  "description": "抖音数据洞察与分析工具",
  "main": "index.js",
  "scripts": {
    "start": "electron . --no-sandbox",
    "dev": "concurrently -k \"vite\" \"electron . --dev --no-sandbox\"",
    "vite": "vite",
    "vite:build": "vite build",
    "vite:preview": "vite preview",
    "electron:dev": "electron . --dev --no-sandbox",
    "dev:full": "concurrently -k \"vite\" \"electron . --dev --no-sandbox\"",
    "build": "vite build && electron-builder",
    "build:mac": "vite build && electron-builder --mac",
    "build:win": "vite build && electron-builder --win",
    "build:linux": "vite build && electron-builder --linux",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.douyin.insight",
    "productName": "抖音数据洞察",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "index.js",
      "preload.js",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg"
      ],
      "icon": "build/icon.icns"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "build/icon.png",
      "category": "Utility",
      "publish": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "artifactName": "douyin-insight-${version}-${os}-${arch}.${ext}",
    "publish": null
  },
  "dependencies": {
    "axios": "^1.6.0",
    "chart.js": "^4.4.0",
    "date-fns": "^3.6.0",
    "electron-store": "^8.1.0",
    "node-notifier": "^10.0.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tdesign-react": "^1.8.0",
    "xlsx": "^0.18.5",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "png-to-ico": "^3.0.1",
    "typescript": "^5.9.3",
    "vite": "^7.0.0"
  }
}
